# Python bytecode / caches
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
env/

# Test / coverage caches
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.mypy_cache/
.ruff_cache/

# Build / packaging output (for when we add PyInstaller later)
build/
dist/
*.egg-info/
*.spec

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Local logs and scratch dumps from balance sims
*.log
balance_run_*.csv
balance_sweep_*.csv
/tmp/

# Local save files (defrag.exe saves to XDG_DATA_HOME, so they normally won't
# land in the repo, but ignore any that get copied here)
saves/
*.save
